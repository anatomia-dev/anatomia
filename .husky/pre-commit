#!/usr/bin/env sh
# Pre-commit: run the packages/cli typecheck + test-typecheck + lint.
# Runs ~9s locally. Full checks fit under the 10s threshold so lint-staged
# isn't needed yet.
#
# To bypass intentionally (e.g., WIP commit): git commit --no-verify.
# Do NOT --no-verify unless you're explicitly handing off a broken tree.

set -e

# Verify lockfile is in sync with package.json (catches desync before push)
# Runs before the skip block so website-only commits still check lockfile sync.
#
# Two checks:
# 1. If lockfile is staged, block if any package.json has unstaged changes.
#    Catches: pnpm install bumps both files, only lockfile gets staged.
# 2. frozen-lockfile checks disk consistency (lockfile vs package.json on disk).
if git diff --cached --name-only | grep -q "^pnpm-lock.yaml$"; then
  UNSTAGED_PKGS=$(git diff --name-only | grep "package\.json$" || true)
  if [ -n "$UNSTAGED_PKGS" ]; then
    echo "❌ pnpm-lock.yaml is staged but package.json has unstaged changes:"
    echo "$UNSTAGED_PKGS"
    echo "   Stage both: git add package.json pnpm-lock.yaml"
    exit 1
  fi
fi
pnpm install --frozen-lockfile --silent 2>/dev/null || {
  echo "❌ pnpm-lock.yaml is out of sync with package.json. Run 'pnpm install' first."
  exit 1
}

# Skip build/typecheck/lint for commits that only touch .ana/ or .claude/ files
# (proof chain updates, skill edits, agent definitions — no TypeScript to check)
STAGED_FILES=$(git diff --cached --name-only)
if [ -n "$STAGED_FILES" ]; then
  NON_ANA_FILES=$(echo "$STAGED_FILES" | grep -v '^\.ana/' | grep -v '^\.claude/' | grep -v '^website/' || true)
  if [ -z "$NON_ANA_FILES" ]; then
    exit 0
  fi
fi

cd packages/cli
pnpm run build
pnpm typecheck
pnpm typecheck:tests
pnpm lint
