#!/usr/bin/env sh
# Pre-commit: run the packages/cli typecheck + test-typecheck + lint.
# Runs ~9s locally. Full checks fit under the 10s threshold so lint-staged
# isn't needed yet.
#
# To bypass intentionally (e.g., WIP commit): git commit --no-verify.
# Do NOT --no-verify unless you're explicitly handing off a broken tree.

set -e

# Lockfile sync — ensures pnpm-lock.yaml travels with package.json.
# Runs before the skip block so website-only commits still check lockfile sync.
#
# History: this hook was patched 4 times in one week (508aa20f, eb96c1ba,
# f34d0ede, 40341104) for lockfile desync. Root cause: Build agents stage
# package.json but not the lockfile (instruction says "stage only spec files").
# frozen-lockfile validates disk state, not staging-area state, so it passes
# when disk is consistent even if the lockfile isn't staged.
#
# Two layers:
# 1. Staging guard — auto-stages lockfile when package.json is staged.
#    Blocks if lockfile is staged but package.json has unstaged changes.
# 2. frozen-lockfile — validates disk consistency (lockfile matches package.json).
#
# KNOWN LIMITATION: frozen-lockfile passes when lockfile is a SUPERSET of what
# package.json requires. If the lockfile is dirty from an unrelated workspace
# change (e.g., tested a dep in packages/cli/ but committing website/), the
# auto-stage commits extra lockfile entries. Blast radius is cosmetic — extra
# entries, no broken builds, self-corrects on next clean pnpm install.
#
# IF THIS CAUSES A PROBLEM: check whether pnpm-lock.yaml was auto-staged with
# entries from an unrelated workspace. Run: git diff HEAD~1 pnpm-lock.yaml
# to see what was committed. If entries don't correspond to the package.json
# change in the same commit, the auto-stage picked up cross-workspace drift.
# Fix: pnpm install && git add pnpm-lock.yaml && git commit --amend
STAGED_PKGS=$(git diff --cached --name-only | grep "package\.json$" || true)
STAGED_LOCK=$(git diff --cached --name-only | grep "^pnpm-lock.yaml$" || true)
DIRTY_LOCK=$(git diff --name-only | grep "^pnpm-lock.yaml$" || true)
DIRTY_PKGS=$(git diff --name-only | grep "package\.json$" || true)

if [ -n "$STAGED_PKGS" ] && [ -n "$DIRTY_LOCK" ]; then
  echo "ℹ️  Auto-staged pnpm-lock.yaml (triggered by: $STAGED_PKGS)"
  git add pnpm-lock.yaml
fi
if [ -n "$STAGED_LOCK" ] && [ -n "$DIRTY_PKGS" ]; then
  echo "❌ pnpm-lock.yaml is staged but package.json has unstaged changes:"
  echo "$DIRTY_PKGS"
  echo "   Run: git add <package.json files above>"
  exit 1
fi
pnpm install --frozen-lockfile --silent 2>/dev/null || {
  echo "❌ pnpm-lock.yaml is out of sync with package.json. Run 'pnpm install' first."
  exit 1
}

# Skip build/typecheck/lint for commits that only touch .ana/ or .claude/ files
# (proof chain updates, skill edits, agent definitions — no TypeScript to check)
STAGED_FILES=$(git diff --cached --name-only)
if [ -n "$STAGED_FILES" ]; then
  NON_ANA_FILES=$(echo "$STAGED_FILES" | grep -v '^\.ana/' | grep -v '^\.claude/' | grep -v '^website/' || true)
  if [ -z "$NON_ANA_FILES" ]; then
    exit 0
  fi
fi

cd packages/cli
pnpm run build
pnpm typecheck
pnpm typecheck:tests
pnpm lint
